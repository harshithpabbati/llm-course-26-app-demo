<cell id="cell-3"># Cell 3: Load models (runs once, stays in memory)
from transformers import DonutProcessor, VisionEncoderDecoderModel
from sentence_transformers import SentenceTransformer

print('Loading Donut model...')
DONUT_MODEL_ID = 'naver-clova-ix/donut-base-finetuned-cord-v2'
donut_processor = DonutProcessor.from_pretrained(DONUT_MODEL_ID)
donut_model = VisionEncoderDecoderModel.from_pretrained(DONUT_MODEL_ID)
donut_model.to(device)
donut_model.eval()
print('Donut loaded.')

print('Loading BGE embedding model...')
BGE_MODEL_ID = 'BAAI/bge-small-en-v1.5'
embed_model = SentenceTransformer(BGE_MODEL_ID, device=device)
print('BGE loaded.')

print('All models ready.')</cell id="cell-3">
<cell id="cell-4"># Cell 4: Define the FastAPI inference server
import io
import re
import base64
import json
import torch
import pytesseract
import pdfplumber
from PIL import Image, ImageEnhance, ImageFilter
from pdf2image import convert_from_bytes
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from typing import List, Optional, Tuple

app = FastAPI(title='DocBrain GPU Inference Server')


# ── Request / Response models ─────────────────────────────────────────────────

class ParseRequest(BaseModel):
    file_b64: str          # base64-encoded file bytes
    filename: str          # used to detect extension
    use_donut: bool = True # if False, skip Donut and use Tesseract only

class ParseResponse(BaseModel):
    raw_text: str
    donut_json: Optional[dict] = None
    method: str            # 'donut', 'tesseract', 'pdfplumber'

class EmbedRequest(BaseModel):
    texts: List[str]

class EmbedResponse(BaseModel):
    embeddings: List[List[float]]
    model: str


# ── Image preprocessing ───────────────────────────────────────────────────────

def preprocess_for_donut(image: Image.Image) -> Image.Image:
    """Resize and enhance image for best Donut accuracy."""
    # Donut was trained on 1280x960 images
    TARGET_W, TARGET_H = 1280, 960
    image = image.convert('RGB')

    # Resize preserving aspect ratio then pad to target
    img_w, img_h = image.size
    scale = min(TARGET_W / img_w, TARGET_H / img_h)
    new_w, new_h = int(img_w * scale), int(img_h * scale)
    image = image.resize((new_w, new_h), Image.LANCZOS)

    # Paste onto white background of target size
    canvas = Image.new('RGB', (TARGET_W, TARGET_H), (255, 255, 255))
    offset_x = (TARGET_W - new_w) // 2
    offset_y = (TARGET_H - new_h) // 2
    canvas.paste(image, (offset_x, offset_y))

    # Enhance contrast and sharpness for better OCR
    canvas = ImageEnhance.Contrast(canvas).enhance(1.5)
    canvas = ImageEnhance.Sharpness(canvas).enhance(1.5)
    return canvas


def preprocess_for_tesseract(image: Image.Image) -> Image.Image:
    """Enhance image for Tesseract OCR."""
    # Upscale if too small
    w, h = image.size
    if max(w, h) < 1600:
        scale = 1600 / max(w, h)
        image = image.resize((int(w * scale), int(h * scale)), Image.LANCZOS)

    # Grayscale + contrast + sharpness
    image = image.convert('L')
    image = ImageEnhance.Contrast(image).enhance(2.0)
    image = ImageEnhance.Sharpness(image).enhance(2.0)
    return image


# ── CORD JSON → readable text ─────────────────────────────────────────────────

def cord_json_to_text(parsed: dict) -> str:
    """Convert Donut CORD JSON output to human-readable text for the LLM."""
    lines = []

    # Store name
    store = parsed.get('store_name') or parsed.get('store_addr', '')
    if store:
        lines.append(f"Store: {store}")

    # Line items
    menu = parsed.get('menu', [])
    if menu:
        lines.append("Items:")
        for item in menu:
            name = item.get('nm') or item.get('sub_nm') or 'Item'
            price = item.get('price') or item.get('unitprice') or ''
            cnt = item.get('cnt', '')
            if cnt and cnt != '1':
                lines.append(f"  - {name} x{cnt}: {price}")
            else:
                lines.append(f"  - {name}: {price}")

    # Totals
    sub = parsed.get('sub_total', {})
    if sub:
        subtotal = sub.get('subtotal_price') or sub.get('subtotal') or ''
        if subtotal:
            lines.append(f"Subtotal: {subtotal}")

    tax = parsed.get('tax', {})
    if tax:
        tax_price = tax.get('tax_price') or tax.get('tax') or ''
        if tax_price:
            lines.append(f"Tax: {tax_price}")

    total = parsed.get('total', {})
    if total:
        total_price = total.get('total_price') or total.get('cashprice') or total.get('total') or ''
        if total_price:
            lines.append(f"TOTAL: {total_price}")

    # Date
    date = parsed.get('date') or parsed.get('time') or ''
    if date:
        lines.append(f"Date: {date}")

    # Payment
    payment = parsed.get('payment', {})
    if payment:
        method = payment.get('type') or payment.get('payment_type') or ''
        if method:
            lines.append(f"Payment: {method}")

    # Fallback: dump raw JSON if nothing extracted
    if len(lines) <= 1:
        return json.dumps(parsed, indent=2)

    return '\n'.join(lines)


# ── OCR helpers ───────────────────────────────────────────────────────────────

def donut_parse_image(image: Image.Image) -> Tuple[str, dict]:
    """Run Donut on a PIL image. Returns (readable_text, structured_json)."""
    preprocessed = preprocess_for_donut(image)

    task_prompt = '<s_cord-v2>'
    decoder_input_ids = donut_processor.tokenizer(
        task_prompt, add_special_tokens=False, return_tensors='pt'
    ).input_ids.to(device)

    pixel_values = donut_processor(
        preprocessed, return_tensors='pt'
    ).pixel_values.to(device)

    with torch.no_grad():
        outputs = donut_model.generate(
            pixel_values,
            decoder_input_ids=decoder_input_ids,
            max_length=donut_model.decoder.config.max_position_embeddings,
            early_stopping=True,
            pad_token_id=donut_processor.tokenizer.pad_token_id,
            eos_token_id=donut_processor.tokenizer.eos_token_id,
            use_cache=True,
            num_beams=1,
            bad_words_ids=[[donut_processor.tokenizer.unk_token_id]],
            return_dict_in_generate=True,
        )

    sequence = donut_processor.batch_decode(outputs.sequences)[0]
    sequence = sequence.replace(donut_processor.tokenizer.eos_token, '')
    sequence = sequence.replace(donut_processor.tokenizer.pad_token, '')
    sequence = re.sub(r'<.*?>', '', sequence, count=1).strip()

    parsed = donut_processor.token2json(sequence)

    # Convert CORD JSON to readable text + keep raw JSON for reference
    readable_text = cord_json_to_text(parsed)

    # Append raw JSON at the end so the extractor can also use it
    full_text = readable_text + '\n\nCORD JSON:\n' + json.dumps(parsed, indent=2)
    return full_text, parsed


def tesseract_image(image: Image.Image) -> str:
    """Enhanced Tesseract OCR with preprocessing."""
    preprocessed = preprocess_for_tesseract(image)
    # PSM 6: uniform block of text (good for receipts)
    text = pytesseract.image_to_string(preprocessed, config='--psm 6 --oem 3').strip()
    if not text:
        # PSM 4: single column fallback
        text = pytesseract.image_to_string(preprocessed, config='--psm 4 --oem 3').strip()
    return text


def extract_pdf_text(file_bytes: bytes) -> Tuple[str, str]:
    """Try pdfplumber first; fall back to Tesseract on scanned pages."""
    text = ''
    with pdfplumber.open(io.BytesIO(file_bytes)) as pdf:
        for page in pdf.pages:
            t = page.extract_text()
            if t:
                text += t + '\n'

    if text.strip():
        return text.strip(), 'pdfplumber'

    pages = convert_from_bytes(file_bytes, dpi=300)
    ocr_text = '\n'.join(tesseract_image(p) for p in pages)
    return ocr_text.strip(), 'tesseract'


# ── Endpoints ─────────────────────────────────────────────────────────────────

@app.get('/health')
def health():
    return {'status': 'ok', 'device': device}


@app.post('/parse', response_model=ParseResponse)
def parse_document(req: ParseRequest):
    file_bytes = base64.b64decode(req.file_b64)
    ext = req.filename.rsplit('.', 1)[-1].lower()

    if ext == 'pdf':
        raw_text, method = extract_pdf_text(file_bytes)
        return ParseResponse(raw_text=raw_text, method=method)

    image = Image.open(io.BytesIO(file_bytes)).convert('RGB')

    if req.use_donut:
        try:
            raw_text, donut_json = donut_parse_image(image)
            # If Donut returned meaningful content (more than just empty JSON)
            if len(raw_text.strip()) > 20:
                print(f'[Donut] Success: {len(raw_text)} chars')
                return ParseResponse(raw_text=raw_text, donut_json=donut_json, method='donut')
            else:
                print('[Donut] Output too short, falling back to Tesseract')
        except Exception as e:
            print(f'[Donut] Failed ({e}), falling back to Tesseract')

    # Tesseract fallback with enhanced preprocessing
    raw_text = tesseract_image(image)
    print(f'[Tesseract] Got {len(raw_text)} chars')
    return ParseResponse(raw_text=raw_text, method='tesseract')


@app.post('/embed', response_model=EmbedResponse)
def embed_texts(req: EmbedRequest):
    if not req.texts:
        raise HTTPException(status_code=400, detail='texts list is empty')
    embeddings = embed_model.encode(
        req.texts, normalize_embeddings=True, show_progress_bar=False
    ).tolist()
    return EmbedResponse(embeddings=embeddings, model=BGE_MODEL_ID)


print('Server defined.')</cell id="cell-4">
<cell id="cell-5"># Cell 5: Start ngrok tunnel and run server
import nest_asyncio
import uvicorn
import threading
from pyngrok import ngrok, conf
from google.colab import userdata

nest_asyncio.apply()

NGROK_TOKEN = userdata.get('NGROK_TOKEN')
conf.get_default().auth_token = NGROK_TOKEN

# Kill any existing tunnels
ngrok.kill()

# Open tunnel on port 8001
public_url = ngrok.connect(8001).public_url
print('\n' + '='*60)
print(f'  DocBrain GPU Server: {public_url}')
print('='*60)
print(f'  Add to backend/.env:  COLAB_URL={public_url}')
print('='*60 + '\n')

# Run server in a background thread so the cell doesn't block
def run():
    uvicorn.run(app, host='0.0.0.0', port=8001, log_level='warning')

t = threading.Thread(target=run, daemon=True)
t.start()
print('Server running. Keep this cell alive (do not interrupt).')</cell id="cell-5">
